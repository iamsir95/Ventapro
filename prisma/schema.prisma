// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Category {
  id            String     @id @default(uuid())
  name          String
  parentId      String?
  parent        Category?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  subCategories Category[] @relation("MenuHierarchy")
  products      Product[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Product {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  brand       String
  basePrice   Decimal
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  
  specs       String           @default("{}") // Replaced Json with String for SQLite compatibility
  
  isNew       Boolean          @default(false)
  isHot       Boolean          @default(false)
  discountPct Int              @default(0)
  
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([brand])
  @@index([categoryId])
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  sku         String   @unique
  name        String   
  
  priceObj    Decimal? 
  stock       Int      @default(0)
  
  attributes  String   @default("{}") // Replaced Json with String for SQLite compatibility
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sku])
}

// Orders
model Order {
  id            String      @id @default(uuid())
  userId        String      
  totalAmount   Decimal
  status        String      @default("PENDING") // Replaced enum with String for SQLite compatibility
  paymentIntent String?     
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id          String         @id @default(uuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id])
  variantId   String
  quantity    Int
  price       Decimal        
}

// -----------------------------------------------------------------------------
// NextAuth / Auth.js Required Models
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For custom Credentials provider (Email/Password)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
